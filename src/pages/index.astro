---
import HeroShell from '../components/aeon/HeroShell';
import MissionsSection from '../components/MissionsSection';
import StatsSection from '../components/StatsSection';
import {
  heroContent,
  heroLeftNav,
  heroRightNav,
  mobileNav,
  stats,
} from '../data/site';
import { getProjectEntries, toProjectCard } from '../lib/content';
import '../styles/global.css';

const projectEntries = await getProjectEntries();
---

<html lang="en" class="bg-page-bg">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Tyler Staut — Security engineer, builder, and explorer navigating the intersection of infrastructure, software, and security."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;800;900&family=Space+Grotesk:wght@300;400;500;700&display=swap"
    />
    <script is:inline>
      (() => {
        const key = 'aeon-theme';
        const stored = window.localStorage.getItem(key);
        const theme = stored === 'light' || stored === 'dark' ? stored : 'dark';
        document.documentElement.dataset.theme = theme;
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <title>Tyler Staut</title>
  </head>
  <body class="bg-page-bg font-body text-white antialiased">
    <main class="site-shell overflow-x-clip">
      <HeroShell
        client:load
        content={heroContent}
        leftNav={heroLeftNav}
        mobileNav={mobileNav}
        rightNav={heroRightNav}
      />
      <MissionsSection client:visible missions={projectEntries.map(toProjectCard)} />
      <StatsSection client:visible stats={stats} />
    </main>
  </body>
</html>
