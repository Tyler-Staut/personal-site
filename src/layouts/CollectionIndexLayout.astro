---
import SiteLayout from './SiteLayout.astro';

interface Props {
  description?: string;
  intro: string;
  title: string;
  eyebrow: string;
}

const { description, eyebrow, intro, title } = Astro.props;
---

<SiteLayout title={title} description={description}>
  <main class="mx-auto max-w-7xl px-6 py-16 sm:px-8 sm:py-20 lg:px-12 lg:py-24">
    <section class="max-w-4xl">
      <p class="font-display text-[11px] uppercase tracking-[0.28em] text-accent-blue">{eyebrow}</p>
      <h1 class="mt-5 break-words font-display text-[2.85rem] leading-none font-bold text-white sm:text-6xl lg:text-7xl">{title}</h1>
      <p class="mt-7 max-w-3xl text-lg leading-8 text-white/65 sm:text-xl">{intro}</p>
    </section>
    <section class="mt-14">
      <slot />
    </section>
  </main>
</SiteLayout>
